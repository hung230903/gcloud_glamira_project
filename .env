DATA_DIR="./data"

# Mongo
MONGODB_URI="mongodb://localhost:27018/"
MONGODB_DB_NAME="glamira"
MONGODB_RAW_DATA_COL="summary"
MONGODB_IP2LOCATION_COL="ip_location"
MONGODB_PRODUCT_EVENTS='["view_product_detail", "select_product_option", "select_product_option_quality", "add_to_cart_action", "product_detail_recommendation_visible", "product_detail_recommendation_noticed", "product_view_all_recommend_clicked"]'
PID_FILTER_DIR_NAME="pid_filter"
PID_FILTER_BATCH_SIZE=500

# Crawler
PRODUCT_CRAWLER_DIR_NAME="product_info"
PRODUCT_CRAWLER_BATCH_SIZE=500
PRODUCT_CRAWLER_SEMAPHORE=10
PRODUCT_CRAWLER_TIMEOUT=15
PRODUCT_CRAWLER_MAX_RETRIES=3
PRODUCT_CRAWLER_HEADERS='{"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8", "Accept-Language": "en-US,en;q=0.9", "Connection": "keep-alive", "Upgrade-Insecure-Requests": "1"}'

# ip2location
IP2LOCATION_DIR_NAME="ip2location"
IP2LOCATION_BATCH_SIZE=100000
IP2LOCATION_DB_FILE="./IP2LOCATION-LITE-DB11.BIN"

# GCS
SUCCESS_DIR="data/product_info/success"
GCS_BUCKET_NAME="glamira_project_bucket"
GCS_DESTINATION_FOLDER="product_info"
GCS_IP2LOCATION_FOLDER="ip2location"

# BigQuery
BQ_PROJECT_ID="concise-voice-486808-m9"
BQ_DATASET_ID="glamira_project"
BQ_TABLE_SUMMARY="summary"
BQ_TABLE_IP2LOCATION="ip2location"
BQ_TABLE_PRODUCT_INFO="product_info"
